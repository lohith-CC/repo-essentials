{
  "name": "repo-essentials",
  "version": "1.0.0",
  "description": "Universal repo safety, review, and writing skills for any project type",
  "author": {
    "name": "Lohith H G",
    "email": "lohithhggjc@gmail.com"
  },
  "keywords": ["safety", "security", "review", "git", "writing", "audit", "changelog"],
  "skills": "skills",
  "hooks": "hooks/hooks.json",
  "mcpServers": {
    "context7": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp"]
    },
    "filesystem": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-filesystem", "${WORKSPACE_DIR:-/}"]
    }
  }
}
